{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dexa.art/learnmap/schema/secondary/high-profile.schema.json",
  "title": "Korean Secondary Learning Map — high-school profile",
  "$ref": "#/$defs/release",
  "$defs": {
    "release": {
      "type": "object",
      "required": [
        "$schema",
        "releaseId",
        "profile",
        "schoolLevel",
        "curriculumVersion",
        "status",
        "createdDate",
        "sourceManifest",
        "rightsStatus",
        "textPolicy",
        "collections",
        "counts"
      ],
      "properties": {
        "$schema": { "type": "string", "format": "uri-reference" },
        "releaseId": {
          "type": "string",
          "pattern": "^kr-2022-high-v[0-9]+\\.[0-9]+(?:\\.[0-9]+)?(?:-[a-z0-9.-]+)?$"
        },
        "profile": { "const": "high" },
        "schoolLevel": { "const": "high" },
        "curriculumVersion": { "const": "2022-revised" },
        "status": { "enum": ["design-skeleton", "inventory", "candidate", "formal-release"] },
        "createdDate": { "type": "string", "format": "date" },
        "sourceManifest": { "type": "string", "pattern": "^\\.\\./shared/[^/]+\\.json$" },
        "rightsStatus": { "$ref": "core.schema.json#/$defs/rightsStatus" },
        "textPolicy": { "$ref": "core.schema.json#/$defs/textPolicy" },
        "collections": {
          "type": "object",
          "required": [
            "subjectGroups",
            "courses",
            "domains",
            "standards",
            "topics",
            "clusters",
            "learningRelations",
            "courseRelations",
            "creditRules",
            "choiceSets",
            "pathways",
            "reviewRecords",
            "coverageGaps"
          ],
          "properties": {
            "subjectGroups": { "const": "subject-groups.json" },
            "courses": { "const": "courses.json" },
            "domains": { "const": "domains.json" },
            "standards": { "const": "standards.json" },
            "topics": { "const": "topics.json" },
            "clusters": { "const": "clusters.json" },
            "learningRelations": { "const": "learning-relations.json" },
            "courseRelations": { "const": "course-relations.json" },
            "creditRules": { "const": "credit-rules.json" },
            "choiceSets": { "const": "choice-sets.json" },
            "pathways": { "const": "pathways.json" },
            "reviewRecords": { "const": "review-records.json" },
            "coverageGaps": { "const": "coverage-gaps.json" }
          },
          "additionalProperties": false
        },
        "counts": {
          "type": "object",
          "required": [
            "subjectGroups",
            "courses",
            "domains",
            "standards",
            "topics",
            "clusters",
            "learningRelations",
            "courseRelations",
            "creditRules",
            "choiceSets",
            "pathways",
            "reviewRecords",
            "coverageGaps"
          ],
          "properties": {
            "subjectGroups": { "type": "integer", "minimum": 0 },
            "courses": { "type": "integer", "minimum": 0 },
            "domains": { "type": "integer", "minimum": 0 },
            "standards": { "type": "integer", "minimum": 0 },
            "topics": { "type": "integer", "minimum": 0 },
            "clusters": { "type": "integer", "minimum": 0 },
            "learningRelations": { "type": "integer", "minimum": 0 },
            "courseRelations": { "type": "integer", "minimum": 0 },
            "creditRules": { "type": "integer", "minimum": 0 },
            "choiceSets": { "type": "integer", "minimum": 0 },
            "pathways": { "type": "integer", "minimum": 0 },
            "reviewRecords": { "type": "integer", "minimum": 0 },
            "coverageGaps": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "subjectGroup": {
      "allOf": [
        { "$ref": "core.schema.json#/$defs/baseRecord" },
        { "type": "object", "required": ["schoolLevel"], "properties": { "schoolLevel": { "const": "high" } } }
      ],
      "unevaluatedProperties": false
    },
    "course": {
      "allOf": [
        { "$ref": "core.schema.json#/$defs/baseRecord" },
        {
          "type": "object",
          "required": ["schoolLevel", "subjectGroupId", "courseCategory", "programScopes", "gradeScope", "creditRuleRefs"],
          "properties": {
            "schoolLevel": { "const": "high" },
            "subjectGroupId": { "$ref": "core.schema.json#/$defs/stableId" },
            "courseCategory": {
              "enum": [
                "common",
                "general-elective",
                "career-elective",
                "convergence-elective",
                "specialized-common",
                "major-general",
                "major-practical"
              ]
            },
            "programScopes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["general", "special-purpose", "specialized-vocational", "meister", "all-high-schools"] }
            },
            "gradeScope": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": { "enum": ["10", "11", "12", "10-12"] }
                }
              ]
            },
            "creditRuleRefs": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "core.schema.json#/$defs/stableId" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "domain": {
      "allOf": [
        { "$ref": "core.schema.json#/$defs/baseRecord" },
        {
          "type": "object",
          "required": ["schoolLevel", "courseId"],
          "properties": {
            "schoolLevel": { "const": "high" },
            "courseId": { "$ref": "core.schema.json#/$defs/stableId" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "standard": {
      "allOf": [
        { "$ref": "core.schema.json#/$defs/baseRecord" },
        {
          "type": "object",
          "required": ["courseId", "code", "domainId", "summary", "summaryKind", "sourceLocator", "officialTextIncluded"],
          "properties": {
            "courseId": { "$ref": "core.schema.json#/$defs/stableId" },
            "code": { "type": "string", "minLength": 3 },
            "domainId": { "$ref": "core.schema.json#/$defs/stableId" },
            "summary": { "type": "string", "minLength": 1 },
            "summaryKind": { "const": "mechanical-derivative" },
            "sourceLocator": { "$ref": "core.schema.json#/$defs/sourceLocator" },
            "officialTextIncluded": { "const": false }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "topic": {
      "allOf": [
        { "$ref": "core.schema.json#/$defs/baseRecord" },
        {
          "type": "object",
          "required": ["schoolLevel", "courseIds", "domainId", "types", "description", "evidence", "assessmentPrompts", "standardAlignments"],
          "properties": {
            "schoolLevel": { "const": "high" },
            "courseIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/stableId" } },
            "domainId": { "$ref": "core.schema.json#/$defs/stableId" },
            "types": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["conceptual", "language", "meta", "procedural", "representational"] } },
            "description": { "type": "string", "minLength": 1 },
            "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "assessmentPrompts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "standardAlignments": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["standardId", "alignmentKind", "basis"],
                "properties": {
                  "standardId": { "$ref": "core.schema.json#/$defs/stableId" },
                  "alignmentKind": { "enum": ["introduces", "supports", "extends", "assesses"] },
                  "basis": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "cluster": {
      "allOf": [
        { "$ref": "core.schema.json#/$defs/baseRecord" },
        {
          "type": "object",
          "required": ["courseId", "domainId", "topicIds", "summary"],
          "properties": {
            "courseId": { "$ref": "core.schema.json#/$defs/stableId" },
            "domainId": { "$ref": "core.schema.json#/$defs/stableId" },
            "topicIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/stableId" } },
            "summary": { "type": "string", "minLength": 1 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "learningRelation": {
      "type": "object",
      "required": ["id", "dependentTopicId", "prerequisiteTopicId", "relationKind", "scope", "strength", "reason", "basisKind", "basis", "sourceRefs", "reviewStatus"],
      "properties": {
        "id": { "$ref": "core.schema.json#/$defs/stableId" },
        "dependentTopicId": { "$ref": "core.schema.json#/$defs/stableId" },
        "prerequisiteTopicId": { "$ref": "core.schema.json#/$defs/stableId" },
        "relationKind": { "enum": ["required-prerequisite", "recommended-before"] },
        "scope": { "enum": ["same-course", "cross-course", "same-subject-group", "cross-subject", "cross-school-level"] },
        "strength": { "enum": ["required", "recommended"] },
        "reason": { "type": "string", "minLength": 1 },
        "basisKind": { "const": "official-source" },
        "basis": { "type": "string", "minLength": 1 },
        "sourceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/sourceRef" } },
        "reviewStatus": { "$ref": "core.schema.json#/$defs/reviewStatus" }
      },
      "allOf": [
        {
          "if": { "properties": { "relationKind": { "const": "required-prerequisite" } } },
          "then": { "properties": { "basisKind": { "const": "official-source" }, "strength": { "const": "required" } } }
        }
      ],
      "additionalProperties": false
    },
    "courseRelation": {
      "type": "object",
      "required": ["id", "fromCourseId", "toCourseId", "relationKind", "claimStatus", "reason", "basisKind", "basis", "sourceRefs", "reviewStatus"],
      "properties": {
        "id": { "$ref": "core.schema.json#/$defs/stableId" },
        "fromCourseId": { "$ref": "core.schema.json#/$defs/stableId" },
        "toCourseId": { "$ref": "core.schema.json#/$defs/stableId" },
        "relationKind": { "enum": ["official-prerequisite", "recommended-before", "co-recommended", "extends", "alternative-to", "prepares-for"] },
        "claimStatus": { "enum": ["official-constraint", "reviewed-recommendation", "candidate"] },
        "reason": { "type": "string", "minLength": 1 },
        "basisKind": { "const": "official-source" },
        "basis": { "type": "string", "minLength": 1 },
        "sourceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/sourceRef" } },
        "reviewStatus": { "$ref": "core.schema.json#/$defs/reviewStatus" }
      },
      "allOf": [
        {
          "if": { "properties": { "relationKind": { "const": "official-prerequisite" } } },
          "then": {
            "properties": {
              "claimStatus": { "const": "official-constraint" },
              "sourceRefs": { "minItems": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "creditRule": {
      "type": "object",
      "required": ["id", "labelKorean", "effectiveFrom", "ruleKind", "value", "unit", "sourceRefs", "verificationStatus", "rightsStatus"],
      "properties": {
        "id": { "$ref": "core.schema.json#/$defs/stableId" },
        "labelKorean": { "type": "string", "minLength": 1 },
        "effectiveFrom": { "type": "string", "format": "date" },
        "effectiveTo": { "type": ["string", "null"], "format": "date" },
        "ruleKind": { "enum": ["graduation-total", "curriculum-total", "creative-activities-total", "subject-group-minimum", "course-credit", "attendance-threshold", "achievement-threshold"] },
        "value": { "type": "number", "minimum": 0 },
        "unit": { "enum": ["credits", "percent", "courses"] },
        "sourceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/sourceRef" } },
        "verificationStatus": { "$ref": "core.schema.json#/$defs/verificationStatus" },
        "rightsStatus": { "$ref": "core.schema.json#/$defs/rightsStatus" }
      },
      "additionalProperties": false
    },
    "choiceSet": {
      "type": "object",
      "required": ["id", "labelKorean", "choiceKind", "minimumSelections", "maximumSelections", "courseIds", "ruleBasis", "sourceRefs", "reviewStatus"],
      "properties": {
        "id": { "$ref": "core.schema.json#/$defs/stableId" },
        "labelKorean": { "type": "string", "minLength": 1 },
        "choiceKind": { "enum": ["choose-at-least", "choose-exactly", "choose-up-to", "comparison-only"] },
        "minimumSelections": { "type": "integer", "minimum": 0 },
        "maximumSelections": { "type": ["integer", "null"], "minimum": 0 },
        "courseIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/stableId" } },
        "ruleBasis": { "enum": ["official-curriculum", "local-policy", "illustrative"] },
        "sourceRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/sourceRef" } },
        "reviewStatus": { "$ref": "core.schema.json#/$defs/reviewStatus" }
      },
      "additionalProperties": false
    },
    "pathway": {
      "type": "object",
      "required": ["id", "labelKorean", "pathwayKind", "audience", "steps", "notOfficialRequirement", "reviewStatus"],
      "properties": {
        "id": { "$ref": "core.schema.json#/$defs/stableId" },
        "labelKorean": { "type": "string", "minLength": 1 },
        "pathwayKind": { "enum": ["official-constraint", "reviewed-recommendation", "illustrative"] },
        "audience": { "enum": ["student", "parent", "teacher"] },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["order", "stepKind", "courseIds", "choiceSetId", "reason"],
            "properties": {
              "order": { "type": "integer", "minimum": 1 },
              "stepKind": { "enum": ["foundation", "required", "recommended", "alternative", "extension"] },
              "courseIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "core.schema.json#/$defs/stableId" } },
              "choiceSetId": { "oneOf": [{ "type": "null" }, { "$ref": "core.schema.json#/$defs/stableId" }] },
              "reason": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "notOfficialRequirement": { "type": "boolean" },
        "reviewStatus": { "$ref": "core.schema.json#/$defs/reviewStatus" }
      },
      "allOf": [
        {
          "if": { "properties": { "pathwayKind": { "enum": ["reviewed-recommendation", "illustrative"] } } },
          "then": { "properties": { "notOfficialRequirement": { "const": true } } }
        }
      ],
      "additionalProperties": false
    },
    "subjectGroupCollection": { "$ref": "#/$defs/subjectGroupCollectionShape" },
    "subjectGroupCollectionShape": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "subjectGroups" }, "records": { "items": { "$ref": "#/$defs/subjectGroup" } } } }],
      "unevaluatedProperties": false
    },
    "courseCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "courses" }, "records": { "items": { "$ref": "#/$defs/course" } } } }],
      "unevaluatedProperties": false
    },
    "domainCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "domains" }, "records": { "items": { "$ref": "#/$defs/domain" } } } }],
      "unevaluatedProperties": false
    },
    "standardCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "standards" }, "records": { "items": { "$ref": "#/$defs/standard" } } } }],
      "unevaluatedProperties": false
    },
    "topicCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "topics" }, "records": { "items": { "$ref": "#/$defs/topic" } } } }],
      "unevaluatedProperties": false
    },
    "clusterCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "clusters" }, "records": { "items": { "$ref": "#/$defs/cluster" } } } }],
      "unevaluatedProperties": false
    },
    "learningRelationCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "learningRelations" }, "records": { "items": { "$ref": "#/$defs/learningRelation" } } } }],
      "unevaluatedProperties": false
    },
    "courseRelationCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "courseRelations" }, "records": { "items": { "$ref": "#/$defs/courseRelation" } } } }],
      "unevaluatedProperties": false
    },
    "creditRuleCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "creditRules" }, "records": { "items": { "$ref": "#/$defs/creditRule" } } } }],
      "unevaluatedProperties": false
    },
    "choiceSetCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "choiceSets" }, "records": { "items": { "$ref": "#/$defs/choiceSet" } } } }],
      "unevaluatedProperties": false
    },
    "pathwayCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "pathways" }, "records": { "items": { "$ref": "#/$defs/pathway" } } } }],
      "unevaluatedProperties": false
    },
    "reviewRecordCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "reviewRecords" }, "records": { "items": { "$ref": "core.schema.json#/$defs/reviewRecord" } } } }],
      "unevaluatedProperties": false
    },
    "coverageGapCollection": {
      "allOf": [{ "$ref": "core.schema.json#/$defs/collectionEnvelopeBase" }, { "properties": { "profile": { "const": "high" }, "recordType": { "const": "coverageGaps" }, "records": { "items": { "$ref": "core.schema.json#/$defs/coverageGap" } } } }],
      "unevaluatedProperties": false
    }
  }
}

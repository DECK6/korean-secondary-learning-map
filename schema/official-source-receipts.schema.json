{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dexa.art/learnmap/schema/secondary/official-source-receipts.schema.json",
  "title": "Korean Secondary Learning Map — official source receipts",
  "type": "object",
  "required": ["$schema", "catalogVersion", "sourceCount", "totalBytes", "sources"],
  "properties": {
    "$schema": { "type": "string", "format": "uri-reference" },
    "catalogVersion": { "type": "string", "format": "date" },
    "sourceCount": { "type": "integer", "minimum": 1 },
    "totalBytes": { "type": "integer", "minimum": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "annex", "attachmentNo", "originalName", "localFile", "textFile", "bytes", "sha256", "pdfPages"],
        "properties": {
          "id": { "$ref": "core.schema.json#/$defs/stableId" },
          "annex": { "type": "integer", "minimum": 1, "maximum": 41 },
          "attachmentNo": { "type": "string", "pattern": "^[0-9]+$" },
          "originalName": { "type": "string", "minLength": 5 },
          "localFile": { "type": "string", "pattern": "^sources/official/files/[a-z0-9._:-]+\\.pdf$" },
          "textFile": { "type": "string", "pattern": "^sources/official/text/[a-z0-9._:-]+\\.txt$" },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "pdfPages": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
